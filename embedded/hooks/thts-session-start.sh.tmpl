#!/usr/bin/env bash
# thts session start hook - injects bootstrap instructions
# Requires: jq

set -euo pipefail

# Read session info from stdin (JSON)
INPUT=$(cat)
SESSION_ID=$(echo "$INPUT" | jq -r '.session_id // empty')
CWD=$(echo "$INPUT" | jq -r '.cwd // empty')

# Check if thts is available and repo is initialized
if ! command -v thts &>/dev/null; then
	exit 0
fi
if ! (cd "$CWD" && thts init --check) 2>/dev/null; then
	exit 0
fi

# Mark session as not expanded yet
EXPANDED_FILE="/tmp/thts-expanded-${SESSION_ID}"
rm -f "$EXPANDED_FILE" 2>/dev/null || true

# Output bootstrap context
cat << 'BOOTSTRAP'
## thts Integration (Bootstrap)

This project uses thts for managing thoughts/notes. The thoughts/ directory
is available for research, plans, decisions, and handoffs.

**Quick reference:**
- `/thts-handoff` - Create session handoff document
- `/thts-resume <path>` - Resume from handoff
- `thoughts/searchable/` - Search-friendly hard links

Full instructions load automatically when relevant keywords are detected.
BOOTSTRAP

{{if .IncludeClaudePlanDirective}}
is_claude_plan_directive_enabled() {
	local setting

	setting=$(thts config --json 2>/dev/null | jq -r '.hooks.claudePlanDirective // true' 2>/dev/null || echo "true")
	[[ "${setting,,}" == "true" ]]
}

if is_claude_plan_directive_enabled; then
cat << 'CLAUDE_PLAN_OVERRIDE'
## Plan Mode Directive

After plan mode approval, immediately copy the plan to `thoughts/shared/plans/`
using the naming convention `YYYY-MM-DD-descriptive-name.md` and the plan
template from `thoughts/.templates/plan.md`. Run `thts sync` after writing.

The thoughts copy is THE CANONICAL PLAN — reference it during implementation,
NOT the ~/.claude/plans/ file.
CLAUDE_PLAN_OVERRIDE
fi
{{end}}
